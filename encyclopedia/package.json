{
  "name": "lexicon",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "pm2": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart lexicon",
    "pm2:stop": "pm2 stop lexicon",
    "pm2:push-word": "pm2 start ecosystem.config.cjs --only push-word",
    "test": "playwright test",
    "generate-index": "node scripts/generate-index.mjs",
    "build:ghpages": "node scripts/generate-index.mjs && VITE_DEPLOY_MODE=ghpages VITE_BASE_PATH=/langupedia/ tsc -b && VITE_DEPLOY_MODE=ghpages VITE_BASE_PATH=/langupedia/ vite build && cp dist/index.html dist/404.html"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.161.3",
    "@tanstack/react-virtual": "^3.13.19",
    "react": "^19",
    "react-dom": "^19"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "pm2": "^6.0.14",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  }
}
